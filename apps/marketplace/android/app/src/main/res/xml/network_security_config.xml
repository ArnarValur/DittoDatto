<?xml version="1.0" encoding="utf-8"?>
<!-- Allow cleartext (ws://) to Tailscale mesh IPs for staging.
     Production will use wss:// — this config can be removed then. -->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- Saturn Tailscale IP -->
        <domain includeSubdomains="false">100.87.99.59</domain>
        <!-- Localhost (ADB reverse for dev) -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
