{
  "name": "dittodatto.no",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/web/*",
    "packages/*",
    "packages/mercury-engine"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:admin": "turbo run dev --filter=admin-panel",
    "dev:portal": "turbo run dev --filter=business-portal",
    "dev:public": "turbo run dev --filter=public-marketplace",
    "dev:apps": "turbo run dev --filter=admin-panel --filter=business-portal --filter=public-marketplace",
    "dev:engine": "npm run dev --workspace=@dittodatto/mercury-engine",
    "dev:docker": "docker compose up --build",
    "dev:all": "concurrently \"npm run emulators\" \"npm run dev:engine\" \"npm run dev:apps\"",
    "emulators": "firebase emulators:start --import=./firebase/emulator-data --export-on-exit",
    "build": "turbo run build",
    "build:admin": "turbo run build --filter=admin-panel",
    "build:portal": "turbo run build --filter=business-portal",
    "build:public": "turbo run build --filter=public-marketplace",
    "build:functions": "npm run build --workspace=functions"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.95",
    "@iconify-json/simple-icons": "^1.2.71",
    "turbo": "^2.8.3"
  }
}
