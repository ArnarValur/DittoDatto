rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow users to upload their own avatar
    match /avatars/{userId} {
      allow read: if true; // Avatars are public
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Helper function to check if user has access to company
    function hasCompanyAccess(companyId) {
      return request.auth.token.companyId == companyId
             || (request.auth.token.companyIds is list
                 && companyId in request.auth.token.companyIds);
    }

    // Company media assets (logos, covers, store gallery, staff portraits)
    // Supports both single companyId (legacy) and companyIds array (multi-company)
    match /companies/{companyId}/{allPaths=**} {
      allow read: if true; // Public read for MVP
      
      // Create/Update requires file size and content type validation
      allow create, update: if request.auth != null
        && (request.auth.token.super_admin == true
            || request.auth.token.role == 'super_admin'
            || hasCompanyAccess(companyId))
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      
      // Delete only requires authentication and company access
      allow delete: if request.auth != null
        && (request.auth.token.super_admin == true
            || request.auth.token.role == 'super_admin'
            || hasCompanyAccess(companyId));
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
