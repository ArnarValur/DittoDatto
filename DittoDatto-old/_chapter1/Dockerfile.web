# ─────────────────────────────────────────────────────────────────────────────
# DittoDatto Nuxt SSR — Multi-stage Dockerfile for Cloud Run
# Usage: docker build --build-arg APP_NAME=admin-panel -f Dockerfile.web .
# ─────────────────────────────────────────────────────────────────────────────

# Stage 1: Install dependencies + build
FROM node:22-slim AS builder

ARG APP_NAME
ENV APP_NAME=${APP_NAME}

WORKDIR /build

# 1. Copy root workspace config + lockfile
COPY package.json package-lock.json ./

# 2. Copy shared packages (Nuxt extends these at build time)
COPY packages/shared-types/ packages/shared-types/
COPY packages/ui/ packages/ui/

# 3. Copy the target app
COPY apps/web/${APP_NAME}/ apps/web/${APP_NAME}/

# 4. Install all workspace deps (monorepo-aware)
RUN npm ci

# 5. Build the Nuxt app (produces .output/)
ENV NODE_OPTIONS="--max-old-space-size=4096"
RUN npm run build --workspace=apps/web/${APP_NAME}

# ─────────────────────────────────────────────────────────────────────────────
# Stage 2: Production runtime (minimal)
# ─────────────────────────────────────────────────────────────────────────────
FROM node:22-slim AS runner

ARG APP_NAME

WORKDIR /app

# Copy only the built output
COPY --from=builder /build/apps/web/${APP_NAME}/.output .output/

# Copy service-account.json if it exists (needed for admin-panel SSR auth)
COPY --from=builder /build/apps/web/${APP_NAME}/service-account.json* ./

# Cloud Run contract: listen on PORT (default 8080)
ENV NODE_ENV=production \
    HOST=0.0.0.0 \
    PORT=8080 \
    NITRO_PORT=8080 \
    NITRO_HOST=0.0.0.0

EXPOSE 8080

CMD ["node", ".output/server/index.mjs"]
