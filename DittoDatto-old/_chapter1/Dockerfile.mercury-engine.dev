# MercuryEngine - Development Dockerfile for docker-compose
# Uses tsx watch for hot reload

FROM node:22-slim

WORKDIR /app

# Copy package files
COPY packages/mercury-engine/package.json ./
COPY packages/shared-types /app/shared-types

# Install all dependencies (including dev deps)
RUN npm install

# Source code will be mounted as volume for hot reload
# (See docker-compose.yml volumes section)

ENV PORT=5002
ENV NODE_ENV=development

EXPOSE 5002

# Run with tsx watch for hot reload
CMD ["npx", "tsx", "watch", "src/server.ts"]
