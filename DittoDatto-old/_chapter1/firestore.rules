rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.role == 'super_admin';
    }

    // Check if user is the owner of the company
    function isCompanyOwner(companyId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/companies/$(companyId)).data.ownerId == request.auth.uid;
    }

    // Check if user is a member of the company (via claims OR memberships)
    // Supports both single companyId claim and companyIds array for multi-company users
    function isCompanyMember(companyId) {
      return isSignedIn() && (
        // Check single companyId claim (legacy/primary)
        request.auth.token.companyId == companyId
        // OR check companyIds array (multi-company support)
        || (request.auth.token.companyIds is list
            && companyId in request.auth.token.companyIds)
        // OR check if user document has this as primaryCompanyId
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.primaryCompanyId == companyId
      );
    }
    
    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin();
      allow update: if isOwner(userId) 
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'companyMemberships', 'tier']);
      // New users can create their own profile; super_admin can create any
      allow create: if (isOwner(userId) && !request.resource.data.keys().hasAny(['role', 'companyMemberships', 'tier']))
                    || isSuperAdmin();
      allow delete: if isSuperAdmin();
      
      // Icon Favorites - users can manage their own favorites
      match /iconFavorites/{docId} {
        allow read, write: if isOwner(userId);
      }
      
      // Favorites - users can manage their own favorites (stores, persons)
      match /favorites/{docId} {
        allow read, write: if isOwner(userId);
      }
      
      // Notifications - user-scoped activity/notification cards
      match /notifications/{notifId} {
        // Users can read their own notifications
        allow read: if isOwner(userId);
        // Only Cloud Functions can create notifications (no client writes)
        allow create: if false;
        // Users can mark their own notifications as read/archived
        allow update: if isOwner(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'isArchived']);
        // No client-side deletes
        allow delete: if false;
      }
    }
    
    // --- Companies & Stores ---
    match /companies/{companyId} {
       allow read: if true;
       // Company members and super admins can update company
       allow write: if isSuperAdmin() || isCompanyMember(companyId);
       
       match /stores/{storeId} {
         allow read: if true;
         // Company members and super admins can write to stores
         allow write: if isSuperAdmin() || isCompanyMember(companyId);
         
         // Services are subcollection under stores
         match /services/{serviceId} {
           allow read: if true;
           allow write: if isSuperAdmin() || isCompanyMember(companyId);
         }

         // Service Groups - similar permissions to Services
         match /serviceGroups/{groupId} {
           allow read: if true;
           allow write: if isSuperAdmin() || isCompanyMember(companyId);
         }

         // Resources - physical assets (tables, rooms, stations, equipment, add-ons)
         match /resources/{resourceId} {
           allow read: if true;
           allow write: if isSuperAdmin() || isCompanyMember(companyId);
         }

         // Resource Groups - logical groupings (Main Dining, Outside, VIP Area)
         match /resourceGroups/{groupId} {
           allow read: if true;
           allow write: if isSuperAdmin() || isCompanyMember(companyId);
         }
       }

       // --- Staff Subcollection ---
       // Path: companies/{companyId}/staff/{staffId}
       match /staff/{staffId} {
         // Public users can read bookable staff shown on storefront
         // (needed for staff-aware booking on the public marketplace)
         allow read: if resource.data.isBookable == true
                     && resource.data.showOnStorefront == true
                     && resource.data.status == "active";
         // Company members and super admins can read ALL staff
         allow read: if isSuperAdmin() || isCompanyMember(companyId);
         
         // Only owner or super admin can create staff (invite)
         // Manager-level RBAC for create handled UI-side to avoid extra get() reads
         allow create: if isSuperAdmin() || isCompanyOwner(companyId);

         // Owner or super admin can update any staff
         // Self-update: staff can update their own schedule/availability
         allow update: if isSuperAdmin()
                       || isCompanyOwner(companyId)
                       || (isSignedIn() && resource.data.userId == request.auth.uid
                           && request.resource.data.diff(resource.data)
                              .affectedKeys()
                              .hasOnly(['weeklyShifts', 'dateOverrides', 'isBookable', 'avatarUrl', 'displayName', 'updatedAt']));
         
         // No hard deletes — use status: 'removed' (soft delete)
         allow delete: if isSuperAdmin();
       }

       // --- Customers CRM Subcollection ---
       // Path: companies/{companyId}/customers/{customerId}
       match /customers/{customerId} {
         // Company members can read all customers
         allow read: if isSignedIn() && isCompanyMember(companyId);
         // Company members can create and update customers (portal CRM)
         allow create, update: if isSignedIn() && isCompanyMember(companyId);
         // No hard deletes — use status: 'inactive'
         allow delete: if isSuperAdmin();
       }

       // --- Reservations Subcollection (Restaurant Table Reservations) ---
       // Path: companies/{companyId}/reservations/{reservationId}
       match /reservations/{reservationId} {
         // Company members can read all reservations for their company
         allow read: if isSignedIn() && isCompanyMember(companyId);
         // Public marketplace can create reservations (customer-facing)
         allow create: if isSignedIn();
         // Company members can update reservation status, table assignment, notes
         allow update: if isSignedIn() && isCompanyMember(companyId);
         // No hard deletes — use status: 'cancelled'
         allow delete: if isSuperAdmin();
       }
    }

    // --- Collection Group Rule for Stores ---
    match /{path=**}/stores/{storeId} {
      allow read: if true;
    }
    
    // --- Collection Group Rule for Services ---
    match /{path=**}/services/{serviceId} {
      allow read: if true;
    }
    
    // --- Bookings (top-level for now, may become subcollection) ---
    match /bookings/{bookingId} {
      allow read: if isSignedIn();

      // Company members can update operational fields on their bookings
      // Identity fields (userId, companyId, storeId, serviceId) and financial
      // fields (priceAtTimeOfBooking, currency) remain immutable from client-side.
      allow update: if isSignedIn()
        && isCompanyMember(resource.data.companyId)
        && request.resource.data.diff(resource.data)
           .affectedKeys()
           .hasOnly(['personId', 'status', 'notes', 'cancellationReason', 'updatedAt']);
    }

    // --- Events Collection (top-level) ---
    match /events/{eventId} {
      // Any signed-in user can read events (query filters handle visibility)
      // This is needed because list queries can't check resource.data before execution
      allow read: if isSignedIn();
      // Company members can write their own events
      allow write: if isSignedIn() && isCompanyMember(resource.data.companyId);
      // Super admin can do anything
      allow read, write: if isSuperAdmin();
    }

    // --- Categories ---
    match /categories/{categoryId} {
      allow read: if true;
    }

    // --- Settings ---
    match /settings/general {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // --- Media Collection ---
    match /media/{mediaId} {
      // Helper: Check if user has access to the company (supports multi-company)
      function hasMediaCompanyAccess(companyId) {
        return companyId == request.auth.token.companyId
               || (request.auth.token.companyIds is list
                   && companyId in request.auth.token.companyIds);
      }
      
      // Anyone signed in can read media metadata (URLs are public for MVP)
      allow read: if isSignedIn();
      // Write allowed for super admins or matching company (supports companyIds array)
      allow create: if isSignedIn() 
        && (isSuperAdmin() 
            || hasMediaCompanyAccess(request.resource.data.companyId));
      allow update, delete: if isSignedIn()
        && (isSuperAdmin() 
            || hasMediaCompanyAccess(resource.data.companyId));
    }

    // --- Activity Hub: Activities Collection ---
    match /activities/{activityId} {
      // Users can only read their own activities
      allow read: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      // Super admin can create activities (for sandbox testing)
      allow create: if isSuperAdmin();
      // Users can mark read/archive their own activities
      allow update: if isSignedIn() 
        && resource.data.recipientId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'isArchived']);
      // Admin can read all for compliance
      allow read: if isSuperAdmin();
    }

    // --- Activity Hub: Messages Collection ---
    match /messages/{messageId} {
      // Helper: check if user is a thread participant
      function isThreadParticipant(threadId) {
        return request.auth.uid in get(/databases/$(database)/documents/threads/$(threadId)).data.participantIds;
      }

      // Participants can read messages in their threads
      allow read: if isSignedIn()
        && isThreadParticipant(resource.data.threadId);
      // Thread participants can send messages
      allow create: if isSignedIn()
        && isThreadParticipant(request.resource.data.threadId);
      // Sender can edit their own message
      allow update: if isSignedIn() && resource.data.senderId == request.auth.uid;
      // Admin can read all
      allow read: if isSuperAdmin();
    }

    // --- Activity Hub: Threads Collection ---
    match /threads/{threadId} {
      // Participants can read their threads
      allow read: if isSignedIn() 
        && request.auth.uid in resource.data.participantIds;
      // Anyone signed in can create a thread (support/feedback)
      allow create: if isSignedIn();
      // Participants can update thread status
      allow update: if isSignedIn() 
        && request.auth.uid in resource.data.participantIds;
      // Admin can read all
      allow read: if isSuperAdmin();
    }

    // --- Search Analytics ---
    match /searchEvents/{eventId} {
      // Only Cloud Functions can write (no client writes)
      allow create, update, delete: if false;
      // Super admin can read for analytics dashboard
      allow read: if isSuperAdmin();
    }

    // --- Activity Hub: Broadcasts Collection ---
    match /broadcasts/{broadcastId} {
      // Company members can read/write their broadcasts
      allow read, write: if isSignedIn() 
        && (isSuperAdmin() 
            || resource.data.companyId == request.auth.token.companyId);
      allow create: if isSignedIn()
        && (isSuperAdmin()
            || request.resource.data.companyId == request.auth.token.companyId);
    }

    // --- Feedback Collection ---
    match /feedback/{feedbackId} {
      // Only super admin can read all feedback
      allow read: if isSuperAdmin();
      // Only Cloud Functions create feedback (no client writes)
      allow create: if false;
      // Super admin can update status, priority, tags, adminNotes
      allow update: if isSuperAdmin();
      // No client-side deletes
      allow delete: if false;
    }

    // --- System Alerts (Zero-Fan-Out Broadcasts) ---
    match /systemAlerts/{alertId} {
      // Any signed-in user can read active alerts (zero-fan-out: no per-user writes)
      allow read: if isSignedIn();
      // Only super admin can create/update/delete alerts
      allow write: if isSuperAdmin();
    }
  }
}