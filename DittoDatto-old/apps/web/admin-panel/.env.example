# Firebase Configuration
NUXT_VUEFIRE_API_KEY=your-api-key
NUXT_VUEFIRE_AUTH_DOMAIN=dittodatto.firebaseapp.com
NUXT_VUEFIRE_PROJECT_ID=dittodatto
NUXT_VUEFIRE_STORAGE_BUCKET=dittodatto.appspot.com
NUXT_VUEFIRE_MESSAGING_SENDER_ID=your-sender-id
NUXT_VUEFIRE_APP_ID=your-app-id
NUXT_VUEFIRE_MEASUREMENT_ID=your-measurement-id

# Environment
NUXT_ENV=development
API_ENDPOINT=http://localhost:5001/dittodatto/europe-north2

# Regional Configuration (Norway MVP)
REGION=no
CURRENCY=NOK
LANGUAGE=nb-NO

# Feature Flags
ENABLE_PAYMENTS=false
ENABLE_VOICE_SEARCH=false
ENABLE_AI_ONBOARDING=true

# Logging
LOG_LEVEL=info
